{
  "name": "@koota/svelte",
  "version": "0.0.1",
  "description": "Svelte bindings for Koota",
  "license": "ISC",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "svelte": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "publishConfig": {
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "svelte": "./dist/index.js",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "svelte": "./dist/index.js",
        "default": "./dist/index.js"
      }
    }
  },
  "scripts": {
    "build": "svelte-package -i src",
    "test": "vitest",
    "lint": "oxlint"
  },
  "dependencies": {
    "@koota/core": "workspace:*"
  },
  "devDependencies": {
    "@config/oxlint": "workspace:*",
    "@config/typescript": "workspace:*",
    "@sveltejs/package": "^2.0.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@testing-library/svelte": "^5.2.0",
    "jsdom": "^27.2.0",
    "svelte": "^5.0.0",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "svelte": ">=5"
  }
}
