{
  "name": "root",
  "version": "1.0.0",
  "private": true,
  "license": "ISC",
  "scripts": {
    "bench": "pnpm --filter @koota/benches exec labs",
    "build": "pnpm -F koota build",
    "examples": "tsx ./scripts/examples.ts",
    "release": "pnpm -F koota build && pnpm -F koota test run && pnpm -F koota publish",
    "prepublishOnly": "pnpm -F koota build && pnpm -F koota generate-tests",
    "test": "pnpm -r --filter=!koota test",
    "test:build": "pnpm prepublishOnly && pnpm -F koota test run",
    "lint": "pnpm -r lint",
    "format": "prettier --config .config/prettier/base.json --write .",
    "typecheck": "pnpm -r --filter './packages/*' --filter '!./packages/publish' exec tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "oxlint": "^1.36.0",
    "prettier": "latest",
    "tsx": "latest",
    "typescript": "latest"
  },
  "engines": {
    "node": ">=24.2.0",
    "pnpm": ">=10.12.1"
  },
  "packageManager": "pnpm@10.32.0"
}
